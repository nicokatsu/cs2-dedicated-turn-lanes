<?xml version="1.0" encoding="utf-8"?>
<Project>
	<PropertyGroup>
		<Configuration>Release</Configuration>
		<Platform>Any CPU</Platform>
		<PublishProtocol>FileSystem</PublishProtocol>
		<_TargetId>Folder</_TargetId>
		<TargetFramework>net48</TargetFramework>
		<PublishDir>bin\$(Configuration)\$(TargetFramework)\</PublishDir>
		<ModChannel>Alpha</ModChannel>
		<ModId>DedicatedTurnLanesAlpha</ModId>
		<ModDisplayName>Dedicated Turn Lanes Alpha</ModDisplayName>
		<AssemblyName>DedicatedTurnLanesAlpha</AssemblyName>
		<TargetName>DedicatedTurnLanesAlpha</TargetName>
		<PublishConfigurationPath>Properties\PublishConfiguration.Alpha.xml</PublishConfigurationPath>
		<ModPublisherCommand>NewVersion</ModPublisherCommand>
	</PropertyGroup>
</Project>
